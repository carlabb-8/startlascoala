@{

    ViewData["Title"] = "Despre Noi";
}

<section class="page-hero">

    <div class="page-hero-content">

        <h1>Despre Noi</h1>

        <p>Misiunea magazinului Start la Școală</p>

    </div>

</section>

<section class="about-section">

    <div class="about-grid">

        <div class="about-text">

            <h2>Povestea Noastra</h2>

            <p>
                Start la Școală a fost fondat în 2020 cu un singur scop: să ofere elevilor din România
                acces facil la toate materialele de care au nevoie pentru a învăța și a se dezvolta.
            </p>

            <p>
                De la manuale scolare si culegeri de bacalaureat, pana la rechizite si ghiozdane ergonomice,
                oferim tot ce ai nevoie intr-un singur loc, la preturi accesibile.
            </p>

            <p>
                Ne mandrim cu o selectie atenta de produse verificate, livrare rapida in intreaga tara
                si un serviciu de relatii cu clientii dedicat.
            </p>

        </div>

    </div>

</section>

<section class="stats-section">

    <div class="section-header">
        <h2>In Cifre</h2>

    </div>

    <div class="stats-grid">

        <div class="stat-card">

            <div class="stat-number">500+</div>

            <div class="stat-label">Produse Disponibile</div>

        </div>

        <div class="stat-card">
            <div class="stat-number">10,000+</div>

            <div class="stat-label">Clienti Multumiti</div>

        </div>

        <div class="stat-card">
            <div class="stat-number">24h</div>

            <div class="stat-label">Timp de Livrare</div>

        </div>

        <div class="stat-card">
            <div class="stat-number">5 ani</div>

            <div class="stat-label">De Experienta</div>

        </div>

    </div>

</section>

<section class="contact-section">

    <div class="section-header">
        <h2>Contacteaza-ne</h2>

    </div>

    <div class="contact-grid">

        <div class="contact-item">

            <i class="fas fa-envelope contact-icon"></i>

            <h4>Email</h4>
                <p>contact@startlascoala.ro</p>

        </div>

        <div class="contact-item">
            <i class="fas fa-phone contact-icon"></i>

            <h4>Telefon</h4>
            <p>+40 700 000 000</p>

        </div>

        <div class="contact-item">
            <i class="fas fa-clock contact-icon"></i>

            <h4>Program</h4>
            <p>Luni - Vineri: 9:00 - 18:00</p>

        </div>

        <div class="contact-item">
            <i class="fas fa-map-marker-alt contact-icon"></i>

            <h4>Adresa</h4>
            <p>Arad, Romania</p>

        </div>

    </div>

</section>

