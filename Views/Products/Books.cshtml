@model List<MagazinOnline.Models.Product>

@{

    ViewData["Title"] = "Carti Scolare";
}

<section class="page-hero page-hero-books">

    <div class="page-hero-content">

        <h1><i class="fas fa-book"></i> Carti Scolare</h1>

        <p>Manuale, culegeri, teste BAC si Evaluare Nationala pentru toti elevii</p>

    </div>

</section>

<section class="filter-bar">

    <div class="filter-container">

        <button class="filter-btn active" onclick="filterCategory('all', this)">

            Toate
        </button>

        <button class="filter-btn" onclick="filterCategory('Clasa 5-12', this)">

            Clasa 5-12
        </button>

        <button class="filter-btn" onclick="filterCategory('Materii', this)">

            Materii
        </button>

        <button class="filter-btn" onclick="filterCategory('BAC', this)">

            BAC
        </button>

        <button class="filter-btn" onclick="filterCategory('Evaluare Nationala', this)">

            Evaluare Nationala
        </button>

    </div>

    <div class="sort-container">

        <label for="sortSelect">Sorteaza dupa:</label>

        <select id="sortSelect" class="sort-select" onchange="sortProducts(this.value)">

            <option value="default">Implicit</option>

            <option value="price-asc">Pret crescator</option>

            <option value="price-desc">Pret descrescator</option>

            <option value="name-asc">Nume A-Z</option>

        </select>

    </div>

</section>

<section class="products-section">

    <div id="productsGrid" class="products-grid">

        @foreach (var product in Model)
        {

            <div class="product-card"
                 data-name="@product.Name.ToLower()"
                 data-category="@product.Category.ToLower()"
                 data-subcategory="@product.SubCategory.ToLower()"
                 data-price="@product.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)">

                <div class="product-image">

                    <img src="@product.ImageUrl"
                         alt="@product.Name"
                         onerror="this.src='/images/default.png'" />

                    <div class="product-badge">@product.SubCategory</div>

                </div>

                <div class="product-info">

                    <h3 class="product-name">@product.Name</h3>

                    <p class="product-description">@product.Description</p>

                    <div class="product-footer">

                        <span class="product-price">@product.Price.ToString("F2") Lei</span>

                        <button class="btn btn-add-cart"
                                onclick="addToCart('@Html.Raw(product.Name.Replace("'", "\\'"))', @product.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), '@product.ImageUrl')">

                            <i class="fas fa-cart-plus"></i> Adauga

                        </button>

                    </div>

                </div>

            </div>

        }

    </div>

    <div id="noResults" class="no-results" style="display:none;">

        <div class="no-results-icon">🔍</div>

        <h3>Niciun produs gasit</h3>

        <p>Incearca alt termen de cautare sau alt filtru.</p>

    </div>

</section>

@section Scripts {

    <script>

        function filterCategory(category, btn) {

            const cards = document.querySelectorAll('.product-card');

            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));

            btn.classList.add('active');

            cards.forEach(card => {

                const sub = card.getAttribute('data-subcategory');

                if (category === 'all' || sub.includes(category.toLowerCase())) {
                    card.style.display = '';

                } else {
                    card.style.display = 'none';

                }
            });

            checkNoResults();
        }

        function sortProducts(value) {

            const grid = document.getElementById('productsGrid');

            const cards = Array.from(grid.querySelectorAll('.product-card'));

            cards.sort((a, b) => {

                if (value === 'price-asc' || value === 'price-desc') {

                    const priceA = parseFloat(a.getAttribute('data-price'));

                    const priceB = parseFloat(b.getAttribute('data-price'));

                    return value === 'price-asc' ? priceA - priceB : priceB - priceA;

                }

                if (value === 'name-asc') {

                    const nameA = a.getAttribute('data-name');
                    const nameB = b.getAttribute('data-name');

                    return nameA.localeCompare(nameB);
                }

                return 0;
            });

            cards.forEach(card => grid.appendChild(card));

        }
    </script>
}
