@model List<MagazinOnline.Models.Product>

@{

    ViewData["Title"] = "Acasa";
}

<section class="hero">

    <div class="hero-content">

        <h1 class="hero-title">Bun venit la Start la Școală!</h1>

        <p class="hero-subtitle">Tot ce ai nevoie pentru școală — cărți, rechizite și multe altele.</p>

        <div class="hero-buttons">

            <a href="/Products/Books" class="btn btn-primary">

                <i class="fas fa-book"></i> Carti Scolare

            </a>

            <a href="/Products/Supplies" class="btn btn-secondary">

                <i class="fas fa-pencil-alt"></i> Rechizite

            </a>

        </div>

    </div>

    <div class="hero-image">

        <div class="hero-illustration">

            <span class="big-emoji">📚</span>

        </div>
    </div>

</section>

<section class="categories-section">

    <div class="section-header">

        <h2>Categorii</h2>

        <p>Alege categoria de care ai nevoie</p>

    </div>

    <div class="categories-grid">

        <a href="/Products/Books" class="category-card">

            <div class="category-icon">📖</div>

            <h3>Carti</h3>

            <p>Manuale, culegeri, BAC, Evaluare Nationala</p>

            <span class="category-count">17 produse</span>

        </a>

        <a href="/Products/Supplies" class="category-card">

            <div class="category-icon">✏️</div>

            <h3>Rechizite</h3>

            <p>Caiete, creioane, ghiozdane, instrumente scolare</p>

            <span class="category-count">14 produse</span>

        </a>

        <a href="/Home/About" class="category-card">

            <div class="category-icon">🏫</div>

            <h3>Despre Noi</h3>

            <p>Afla mai multe despre magazinul nostru</p>

            <span class="category-count">Cunoaste-ne</span>

        </a>

    </div>

</section>

<section class="products-section" id="popularProducts">

    <div class="section-header">

        <h2>Produse Populare</h2>

        <p>Cele mai cautate produse de catre elevi</p>

    </div>

    <div class="products-grid" id="productsGrid">

        @foreach (var product in Model)
        {

            <div class="product-card" data-name="@product.Name.ToLower()" data-category="@product.Category.ToLower()" data-subcategory="@product.SubCategory.ToLower()">

                <div class="product-image">

                    <img src="@product.ImageUrl" alt="@product.Name" onerror="this.src='/images/default.png'" />

                    <div class="product-badge">@product.SubCategory</div>

                </div>

                <div class="product-info">

                    <h3 class="product-name">@product.Name</h3>

                    <p class="product-description">@product.Description</p>

                    <div class="product-footer">

                        <span class="product-price">@product.Price.ToString("F2") Lei</span>

                        <button class="btn btn-add-cart"
                                onclick="addToCart('@Html.Raw(product.Name.Replace("'", "\\'"))', @product.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture), '@product.ImageUrl')">

                            <i class="fas fa-cart-plus"></i> Adauga

                        </button>

                    </div>

                </div>

            </div>

        }

    </div>

    <div class="section-footer">

        <a href="/Products/Books" class="btn btn-outline">Vezi toate cartile</a>

        <a href="/Products/Supplies" class="btn btn-outline">Vezi toate rechizitele</a>

    </div>

</section>

<section class="features-section">

    <div class="section-header">
        <h2>De ce să alegi Start la Școală?</h2>

    </div>

    <div class="features-grid">

        <div class="feature-card">

            <div class="feature-icon">🚚</div>

            <h3>Livrare Rapida</h3>

            <p>Livrare in 24-48 de ore in toata tara</p>

        </div>

        <div class="feature-card">
            <div class="feature-icon">💯</div>

            <h3>Produse Originale</h3>
            <p>Toate produsele sunt originale si de calitate</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">🔒</div>

            <h3>Plata Sigura</h3>
            <p>Tranzactii securizate si date protejate</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">🎁</div>

            <h3>Oferte Speciale</h3>
            <p>Reduceri si promotii pentru elevi si studenti</p>
        </div>

    </div>

</section>

