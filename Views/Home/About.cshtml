@* About.cshtml — pagina "Despre Noi" a magazinului *@
@* Nu este necesar niciun model — această pagină conține doar conținut static *@

@{
    @* Setăm titlul ferestrelor browserului pentru această pagină *@
    ViewData["Title"] = "Despre Noi";
}

<!-- ==================== IMAGINEA HERO DESPRE NOI ==================== -->
<!-- Imagine mare cu ilustrație la începutul paginii Despre Noi -->
<div class="about-hero-banner">
    <img src="~/images/despre-noi.png"
         alt="Doi elevi fericiți cu ghiozdane în fața școlii — Start la Școală"
         class="about-hero-img" />
    <!-- Imaginea ilustrativă principală a paginii Despre Noi -->
</div>
<!-- Sfârșitul about-hero-banner -->

<!-- ==================== SECȚIUNEA HERO DESPRE NOI ==================== -->
<!-- Bannerul din partea de sus a paginii Despre Noi -->
<section class="page-hero">

    <div class="page-hero-content">
        <!-- Container pentru textul din banner -->

        <h1>Despre Noi</h1>
        <!-- Titlul principal al paginii: "Despre Noi" -->

        <p>Misiunea magazinului Start la Școală</p>
        <!-- Subtitlu care invită vizitatorii să afle mai multe despre noi -->

    </div>

</section>
<!-- Sfârșitul secțiunii page-hero -->

<!-- ==================== SECȚIUNEA POVESTEA NOASTRĂ ==================== -->
<section class="about-section">

    <div class="about-grid">
        <!-- Grid în două coloane: text în stânga, ilustrație în dreapta -->

        <div class="about-text">
            <!-- Coloana stângă: textul poveștii magazinului -->

            <h2>Povestea Noastra</h2>
            <!-- Subtitlul secțiunii: "Povestea Noastră" -->

            <p>
                Start la Școală a fost fondat în 2020 cu un singur scop: să ofere elevilor din România
                acces facil la toate materialele de care au nevoie pentru a învăța și a se dezvolta.
            </p>
            <!-- Paragraful 1: povestea fondării magazinului -->

            <p>
                De la manuale scolare si culegeri de bacalaureat, pana la rechizite si ghiozdane ergonomice,
                oferim tot ce ai nevoie intr-un singur loc, la preturi accesibile.
            </p>
            <!-- Paragraful 2: ce oferă magazinul nostru -->

            <p>
                Ne mandrim cu o selectie atenta de produse verificate, livrare rapida in intreaga tara
                si un serviciu de relatii cu clientii dedicat.
            </p>
            <!-- Paragraful 3: promisiunea de calitate a magazinului -->

        </div>
        <!-- Sfârșitul about-text -->

        <div class="about-illustration">
            <!-- Coloana dreaptă: logo-ul magazinului afișat decorativ -->
            <div class="about-logo-display">
                <!-- Afișăm logo-ul oficial alături de textul poveștii -->
                <img src="~/images/logo.png"
                     alt="Logo Start la Școală"
                     class="about-logo-img" />
                <!-- Logo-ul oficial al magazinului Start la Școală -->
            </div>
        </div>

    </div>
    <!-- Sfârșitul about-grid -->

</section>
<!-- Sfârșitul about-section -->

<!-- ==================== SECȚIUNEA În CIFRE ==================== -->
<!-- Afișează statistici cheie despre magazin -->
<section class="stats-section">

    <div class="section-header">
        <h2>In Cifre</h2>
        <!-- Titlul secțiunii: statistici despre magazin "În Cifre" -->
    </div>

    <div class="stats-grid">
        <!-- Grid cu 4 casete de statistici -->

        <div class="stat-card">
            <!-- Card individual de statistică -->
            <div class="stat-number">500+</div>
            <!-- Numărul mare afișat proeminent -->
            <div class="stat-label">Produse Disponibile</div>
            <!-- Eticheta sub număr: "Produse Disponibile" -->
        </div>

        <div class="stat-card">
            <div class="stat-number">10,000+</div>
            <!-- Numărul de clienți mulțumiți -->
            <div class="stat-label">Clienti Multumiti</div>
            <!-- Eticheta: "Clienți Mulțumiți" -->
        </div>

        <div class="stat-card">
            <div class="stat-number">24h</div>
            <!-- Timpul rapid de livrare -->
            <div class="stat-label">Timp de Livrare</div>
            <!-- Eticheta: "Timp de Livrare" -->
        </div>

        <div class="stat-card">
            <div class="stat-number">5 ani</div>
            <!-- Numărul de ani de activitate -->
            <div class="stat-label">De Experienta</div>
            <!-- Eticheta: "De Experiență" -->
        </div>

    </div>
    <!-- Sfârșitul stats-grid -->

</section>
<!-- Sfârșitul secțiunii statistici -->

<!-- ==================== SECȚIUNEA CONTACT ==================== -->
<section class="contact-section">

    <div class="section-header">
        <h2>Contacteaza-ne</h2>
        <!-- Titlul secțiunii: "Contactează-ne" -->
    </div>

    <div class="contact-grid">
        <!-- Grid cu metodele de contact -->

        <div class="contact-item">
            <!-- Card individual de contact -->
            <i class="fas fa-envelope contact-icon"></i>
            <!-- Iconiță email -->
            <h4>Email</h4>
                <p>contact@startlascoala.ro</p>
            <!-- Adresa de email a magazinului -->
        </div>

        <div class="contact-item">
            <i class="fas fa-phone contact-icon"></i>
            <!-- Iconiță telefon -->
            <h4>Telefon</h4>
            <p>+40 700 000 000</p>
            <!-- Numărul de telefon -->
        </div>

        <div class="contact-item">
            <i class="fas fa-clock contact-icon"></i>
            <!-- Iconiță ceas pentru programul de lucru -->
            <h4>Program</h4>
            <p>Luni - Vineri: 9:00 - 18:00</p>
            <!-- Programul de lucru al magazinului -->
        </div>

        <div class="contact-item">
            <i class="fas fa-map-marker-alt contact-icon"></i>
            <!-- Iconiță pin de locație -->
            <h4>Adresa</h4>
            <p>Arad, Romania</p>
            <!-- Adresa fizică a magazinului -->
        </div>

    </div>
    <!-- Sfârșitul contact-grid -->

</section>
<!-- Sfârșitul secțiunii contact -->
